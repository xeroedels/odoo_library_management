<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_library_borrowing_tree" model="ir.ui.view">
        <field name="name">library.borrowing.tree</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="date_borrow"/>
                <field name="date_return"/>
                <field name="status"/>
            </list>
        </field>
    </record>

        <record id="view_library_borrowing_form" model="ir.ui.view">
        <field name="name">library.borrowing.form</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="date_borrow"/>
                <field name="date_return"/>
                <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
<record id="action_library_borrowing" model="ir.actions.act_window">
    <field name="name">Borrowing</field>
    <field name="res_model">library.borrowing</field>
    <field name="view_mode">list,form</field>
</record>
<menuitem
    id="menu_library_borrowing"
    name="Borrowing"
    parent="menu_library_root"
    action="action_library_borrowing"/>
</odoo>